{
	"name": "tikzjax",
	"version": "1.0.0",
	"description": "",
	"scripts": {
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "eslint . --fix",
		"lint:check": "eslint .",
		"gen-tex-files": "node genTexFiles.js",
		"encode-tex-files": "node encodeTexFiles.js",
		"install-fonts": "gulp download-fonts && gulp install-fonts && fontforge -lang=py -script patchFonts.py && node encodeFonts.js",
		"build": "webpack --mode production",
		"build:dev": "webpack --mode development",
		"serve": "webpack serve --config-name demo",
		"postbuild": "node cleanup.js && npm run install-fonts"
	},
	"author": "Jim Fowler",
	"contributors": [
		"Glenn Rice"
	],
	"license": "GPL-3.0+",
	"dependencies": {
		"@drgrice1/dvi2html": "file:../dvi2html",
		"buffer": "^6.0.3",
		"fetch-readablestream": "^0.2.0",
		"idb": "^8.0.3",
		"md5": "^2.3.0",
		"pako": "^2.0.2",
		"process": "^0.11.10",
		"stream-browserify": "^3.0.0",
		"threads": "^1.6.3"
	},
	"devDependencies": {
		"@awmottaz/prettier-plugin-void-html": "^1.6.1",
		"@stylistic/eslint-plugin": "^2.12.1",
		"copy-webpack-plugin": "^7.0.0",
		"css-loader": "^5.0.1",
		"decompress": "^4.2.1",
		"eslint": "^9.17.0",
