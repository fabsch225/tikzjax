		"eslint-webpack-plugin": "^4.2.0",
		"fonteditor-core": "^2.4.1",
		"gulp": "^4.0.2",
		"gulp-decompress": "^3.0.0",
		"gulp-download2": "^1.0.2",
		"gulp-filter": "^6.0.0",
		"prettier": "^3.4.2",
		"style-loader": "^4.0.0",
		"webpack": "^5.97.1",
		"webpack-cli": "^5.1.4",
		"webpack-dev-server": "^5.2.0"
	}
